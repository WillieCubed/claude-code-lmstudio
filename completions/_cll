#compdef cll
# zsh completion for cll.
#
# Install: put this file on your $fpath and run compinit, e.g.
#   mkdir -p ~/.zfunc && cp completions/_cll ~/.zfunc/_cll
#   # in ~/.zshrc, before compinit:
#   fpath=(~/.zfunc $fpath); autoload -Uz compinit; compinit
#
# Completes model ids (from `cll --list-models`) after -m/--model/--set-default,
# and cll's own flags otherwise.
_cll() {
  local prev="${words[CURRENT-1]}"
  if [[ "$prev" == (-m|--model|--set-default) ]]; then
    local -a models
    models=(${(f)"$(cll --list-models 2>/dev/null)"})
    compadd -- $models
    return
  fi
  compadd -- -m --model --pick --models --list-models --set-default \
    --clear-default --doctor --lmstudio-url -V --version
}
_cll "$@"
